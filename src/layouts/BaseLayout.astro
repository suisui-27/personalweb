---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "个人作品集 | 工业设计与机械工程",
  description = "工业设计、机械工程、视觉设计、摄影与阶段性作品记录。"
} = Astro.props;

const navItems = [
  ["/portfolio/", "工业产品"],
  ["/posters/", "平面设计"],
  ["/photography/", "摄影作品"],
  ["/honors/", "个人成长"],
];

const isHome = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      {!isHome && (
        <header class="site-header">
          <a class="brand" href="/" aria-label="回到首页">
            <span>主页</span>
          </a>
          <nav class="site-nav" aria-label="主导航">
            {navItems.map(([href, label]) => (
              <a href={href} aria-current={Astro.url.pathname === href ? "page" : undefined}>{label}</a>
            ))}
          </nav>
        </header>
      )}
      <slot />
      <div class="page-transition" aria-hidden="true"><span></span></div>
    </div>
    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const transition = document.querySelector(".page-transition");

      if (transition && !reduceMotion) {
        gsap.set(transition, { autoAlpha: 1 });
        gsap
          .timeline({ defaults: { ease: "power3.out" } })
          .to(transition, { autoAlpha: 0, duration: 0.72 })
          .from(".site-header", { y: -18, autoAlpha: 0, duration: 0.48 }, 0.08)
          .from("main > section, main > .photo-immersive-panel", { y: 18, autoAlpha: 0, duration: 0.62, stagger: 0.06 }, 0.12);

        ScrollTrigger.batch(".reveal-item, .work-card, .honor-tile, .photo-list-item", {
          start: "top 88%",
          once: true,
          onEnter: (elements) => {
            gsap.fromTo(elements, { y: 24, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.62, stagger: 0.06, ease: "power2.out" });
          },
        });

        window.addEventListener("pageshow", () => {
          gsap.to(transition, { autoAlpha: 0, duration: 0.28, overwrite: true });
        });

        document.addEventListener("click", (event) => {
          const target = event.target instanceof Element ? event.target.closest<HTMLAnchorElement>("a") : null;
          if (!target) return;
          const href = target.getAttribute("href");
          if (!href || href.startsWith("#") || target.target || target.hasAttribute("download")) return;

          const url = new URL(href, window.location.href);
          if (url.origin !== window.location.origin || url.pathname === window.location.pathname) return;

          event.preventDefault();
          gsap.to(transition, {
            autoAlpha: 1,
            duration: 0.34,
            ease: "power2.inOut",
            onComplete: () => {
              window.location.href = url.href;
            },
          });
        });
      }
    </script>
  </body>
</html>
