---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  description = "工业设计、机械工程、视觉设计、摄影与阶段性作品记录。"
} = Astro.props;

const siteTitle = "SuisuiGallery";
const documentTitle = siteTitle;

const navItems = [
  ["/portfolio/", "工业产品"],
  ["/posters/", "平面设计"],
  ["/photography/", "摄影作品"],
  ["/honors/", "个人成长"],
];

const isHome = Astro.url.pathname === "/";
const noPageScroll = Astro.url.pathname === "/posters/" || Astro.url.pathname === "/photography/";
---

<!doctype html>
<html lang="zh-CN" class={noPageScroll ? "no-page-scroll-root" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{documentTitle}</title>
  </head>
  <body class={noPageScroll ? "no-page-scroll" : undefined}>
    <div class="site-shell">
      {!isHome && (
        <header class="site-header">
          <a class="brand" href="/" aria-label="回到首页">
            <span>主页</span>
          </a>
          <nav class="site-nav" aria-label="主导航">
            {navItems.map(([href, label]) => (
              <a href={href} aria-current={Astro.url.pathname === href ? "page" : undefined}>{label}</a>
            ))}
          </nav>
        </header>
      )}
      <slot />
      <div class="page-transition" aria-hidden="true">
        <div class="page-turn page-turn-back"></div>
        <div class="page-turn page-turn-front"></div>
        <div class="page-turn page-turn-spine"></div>
      </div>
    </div>
    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const transition = document.querySelector(".page-transition");
      const pageTurnFront = document.querySelector(".page-turn-front");
      const pageTurnBack = document.querySelector(".page-turn-back");
      const pageTurnSpine = document.querySelector(".page-turn-spine");

      const stealthLinks = () => {
        document.querySelectorAll<HTMLAnchorElement>("a[href]").forEach((link) => {
          const href = link.getAttribute("href");
          if (!href || href.startsWith("#") || href.startsWith("javascript:") || href.startsWith("mailto:") || href.startsWith("tel:")) return;
          if (link.hasAttribute("download")) return;
          link.dataset.navHref = href;
          link.removeAttribute("href");
          if (!link.hasAttribute("role")) link.setAttribute("role", "link");
          if (!link.hasAttribute("tabindex")) link.setAttribute("tabindex", "0");
        });
      };

      stealthLinks();

      const navigateWithTransition = (target: HTMLAnchorElement) => {
        const href = target.dataset.navHref;
        if (!href || target.hasAttribute("download")) return;
        const url = new URL(href, window.location.href);
        if (target.target || url.origin !== window.location.origin) {
          window.open(url.href, target.target || "_self", target.rel.includes("noreferrer") ? "noreferrer" : "noopener");
          return;
        }
        if (url.pathname === window.location.pathname && url.search === window.location.search) return;

        if (!transition || reduceMotion) {
          window.location.href = url.href;
          return;
        }

        gsap.killTweensOf([transition, pageTurnFront, pageTurnBack, pageTurnSpine]);
        gsap.set(transition, { autoAlpha: 1, visibility: "visible" });
        gsap.set(pageTurnBack, { autoAlpha: 0 });
        gsap.set(pageTurnFront, { autoAlpha: 1, xPercent: 100 });
        gsap.set(pageTurnSpine, { autoAlpha: 0, xPercent: 100 });

        gsap
          .timeline({
            defaults: { ease: "power3.inOut" },
            onComplete: () => {
              window.location.href = url.href;
            },
          })
          .addLabel("turn", 0)
          .to(pageTurnBack, { autoAlpha: 1, duration: 0.2, ease: "power2.out" }, "turn")
          .to([pageTurnFront, pageTurnSpine], { xPercent: 0, duration: 0.62 }, "turn")
          .to(pageTurnSpine, { autoAlpha: 0.62, duration: 0.18, ease: "power2.out" }, "turn+=0.08")
          .to("main, .site-header", { autoAlpha: 0.34, duration: 0.36, ease: "power2.out" }, "turn+=0.1");
      };

      document.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target.closest<HTMLAnchorElement>("a[data-nav-href]") : null;
        if (!target || event.defaultPrevented) return;
        event.preventDefault();
        navigateWithTransition(target);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Enter") return;
        const target = event.target instanceof Element ? event.target.closest<HTMLAnchorElement>("a[data-nav-href]") : null;
        if (!target) return;
        event.preventDefault();
        navigateWithTransition(target);
      });

      if (transition && !reduceMotion) {
        gsap.set(transition, { autoAlpha: 1, visibility: "visible" });
        gsap.set(pageTurnBack, { autoAlpha: 1 });
        gsap.set(pageTurnFront, { autoAlpha: 1, xPercent: 0 });
        gsap.set(pageTurnSpine, { autoAlpha: 0.62, xPercent: 0 });

        gsap
          .timeline({ defaults: { ease: "power3.out" } })
          .addLabel("open", 0)
          .to([pageTurnFront, pageTurnSpine], { xPercent: -100, duration: 0.68, ease: "power3.inOut" }, "open")
          .to(pageTurnBack, { autoAlpha: 0, duration: 0.24, ease: "power2.out" }, "open+=0.48")
          .to(transition, { autoAlpha: 0, duration: 0.18 }, "open+=0.58")
          .from(".site-header", { y: -10, autoAlpha: 0, duration: 0.34 }, "open+=0.16")
          .from("main > section, main > .photo-immersive-panel", { y: 10, autoAlpha: 0, duration: 0.46, stagger: 0.04 }, "open+=0.2")
          .set(transition, { visibility: "hidden" });

        ScrollTrigger.batch(".reveal-item, .work-card, .honor-tile, .photo-list-item", {
          start: "top 88%",
          once: true,
          onEnter: (elements) => {
            gsap.fromTo(elements, { y: 24, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.62, stagger: 0.06, ease: "power2.out" });
          },
        });

        window.addEventListener("pageshow", () => {
          gsap.to(transition, { autoAlpha: 0, duration: 0.28, overwrite: true, onComplete: () => gsap.set(transition, { visibility: "hidden" }) });
        });
      }
    </script>
  </body>
</html>
