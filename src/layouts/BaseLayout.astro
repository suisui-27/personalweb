---
import "../styles/global.css";

const LocalContentUploader = import.meta.env.DEV
  ? (await import("../components/LocalContentUploader.astro")).default
  : null;
const LocalContentEditor = import.meta.env.DEV
  ? (await import("../components/LocalContentEditor.astro")).default
  : null;

interface Props {
  title?: string;
  description?: string;
}

const {
  description = "工业设计、机械工程、视觉设计、摄影与阶段性作品记录。"
} = Astro.props;

const siteTitle = "SuisuiGallery";
const documentTitle = siteTitle;

const navItems = [
  ["/portfolio/", "工业产品", "portfolio"],
  ["/posters/", "平面设计", "poster"],
  ["/photography/", "摄影作品", "photography"],
  ["/honors/", "个人成长", "honor"],
];

const isHome = Astro.url.pathname === "/";
const noPageScroll = Astro.url.pathname === "/posters/" || Astro.url.pathname === "/photography/";
---

<!doctype html>
<html lang="zh-CN" class={noPageScroll ? "no-page-scroll-root" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <script is:inline>
      try {
        if (localStorage.getItem("suisui-theme") === "light") {
          document.documentElement.dataset.theme = "light";
        }
      } catch {}
    </script>
    <title>{documentTitle}</title>
  </head>
  <body class={noPageScroll ? "no-page-scroll" : undefined}>
    <div class="site-shell">
      {!isHome && (
        <header class="site-header">
          <a class="brand" href="/" aria-label="回到首页" data-local-editor-trigger={import.meta.env.DEV ? "true" : undefined}>
            <span>主页</span>
          </a>
          <nav class="site-nav" aria-label="主导航">
            {navItems.map(([href, label, uploadType]) => (
              <a
                href={href}
                aria-current={Astro.url.pathname === href ? "page" : undefined}
                data-local-upload={import.meta.env.DEV ? uploadType : undefined}
              >{label}</a>
            ))}
            <label class="theme-toggle" aria-label="切换深浅色主题">
              <input type="checkbox" data-theme-toggle />
              <span class="circle">
                <span class="crescent"></span>
              </span>
            </label>
          </nav>
        </header>
      )}
      <slot />
      <div class="site-loader" data-site-loader aria-hidden="true">
        <div class="loader">
          <div class="cube">
            <div class="face"></div>
            <div class="face"></div>
            <div class="face"></div>
            <div class="face"></div>
            <div class="face"></div>
            <div class="face"></div>
          </div>
        </div>
      </div>
      {LocalContentUploader && <LocalContentUploader />}
      {LocalContentEditor && <LocalContentEditor />}
    </div>
    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const siteLoader = document.querySelector<HTMLElement>("[data-site-loader]");
      const themeToggle = document.querySelector<HTMLInputElement>("[data-theme-toggle]");
      const loaderMarkup = `
        <div class="loader">
          <div class="cube">
            <div class="face"></div>
            <div class="face"></div>
            <div class="face"></div>
            <div class="face"></div>
            <div class="face"></div>
            <div class="face"></div>
          </div>
        </div>
      `;

      const showSiteLoader = () => {
        siteLoader?.classList.remove("is-hidden");
        siteLoader?.classList.add("is-visible");
      };

      const hideSiteLoader = () => {
        siteLoader?.classList.remove("is-visible");
        siteLoader?.classList.add("is-hidden");
      };

      const setTheme = (theme: "dark" | "light") => {
        if (theme === "light") {
          document.documentElement.dataset.theme = "light";
        } else {
          document.documentElement.removeAttribute("data-theme");
        }

        if (themeToggle) themeToggle.checked = theme === "light";

        try {
          localStorage.setItem("suisui-theme", theme);
        } catch {}
      };

      const currentTheme = document.documentElement.dataset.theme === "light" ? "light" : "dark";
      setTheme(currentTheme);
      themeToggle?.addEventListener("change", () => setTheme(themeToggle.checked ? "light" : "dark"));

      const stealthLinks = () => {
        document.querySelectorAll<HTMLAnchorElement>("a[href]").forEach((link) => {
          const href = link.getAttribute("href");
          if (!href || href.startsWith("#") || href.startsWith("javascript:") || href.startsWith("mailto:") || href.startsWith("tel:")) return;
          if (link.hasAttribute("download")) return;
          link.dataset.navHref = href;
          link.removeAttribute("href");
          if (!link.hasAttribute("role")) link.setAttribute("role", "link");
          if (!link.hasAttribute("tabindex")) link.setAttribute("tabindex", "0");
        });
      };

      stealthLinks();

      const navigateWithLoader = (target: HTMLAnchorElement) => {
        const href = target.dataset.navHref;
        if (!href || target.hasAttribute("download")) return;
        const url = new URL(href, window.location.href);
        if (target.target || url.origin !== window.location.origin) {
          window.open(url.href, target.target || "_self", target.rel.includes("noreferrer") ? "noreferrer" : "noopener");
          return;
        }
        if (url.pathname === window.location.pathname && url.search === window.location.search) return;

        showSiteLoader();
        window.setTimeout(() => {
          window.location.href = url.href;
        }, 120);
      };

      document.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target.closest<HTMLAnchorElement>("a[data-nav-href]") : null;
        if (!target || event.defaultPrevented) return;
        event.preventDefault();
        navigateWithLoader(target);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Enter") return;
        const target = event.target instanceof Element ? event.target.closest<HTMLAnchorElement>("a[data-nav-href]") : null;
        if (!target) return;
        event.preventDefault();
        navigateWithLoader(target);
      });

      const setImageLoading = (image: HTMLImageElement) => {
        if (!image.currentSrc && !image.src) return;
        if (image.closest(".loader, .asset-loader, .site-loader")) return;
        const parent = image.parentElement;
        if (!parent) return;

        parent.classList.add("has-asset-loader");
        let loader = parent.querySelector<HTMLElement>(":scope > .asset-loader");
        if (!loader) {
          loader = document.createElement("div");
          loader.className = "asset-loader";
          loader.setAttribute("aria-hidden", "true");
          loader.innerHTML = loaderMarkup;
          parent.appendChild(loader);
        }

        const hideAssetLoader = () => {
          parent.classList.remove("is-asset-loading");
          loader?.classList.add("is-hidden");
        };

        if (image.complete && image.naturalWidth > 0) {
          hideAssetLoader();
          return;
        }

        loader.classList.remove("is-hidden");
        parent.classList.add("is-asset-loading");
        image.addEventListener("load", hideAssetLoader, { once: true });
        image.addEventListener("error", hideAssetLoader, { once: true });
      };

      const bindImageLoaders = (root: ParentNode = document) => {
        root.querySelectorAll<HTMLImageElement>("img").forEach(setImageLoading);
      };

      bindImageLoaders();
      const mediaObserver = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === "attributes" && mutation.target instanceof HTMLImageElement) {
            setImageLoading(mutation.target);
            return;
          }

          mutation.addedNodes.forEach((node) => {
            if (!(node instanceof Element)) return;
            if (node instanceof HTMLImageElement) setImageLoading(node);
            bindImageLoaders(node);
          });
        });
      });
      mediaObserver.observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ["src", "srcset"] });

      window.addEventListener("load", hideSiteLoader, { once: true });
      window.addEventListener("pageshow", hideSiteLoader);

      if (!reduceMotion) {
        gsap
          .timeline({ defaults: { ease: "power3.out" } })
          .from(".site-header", { y: -10, autoAlpha: 0, duration: 0.34 }, 0.08)
          .from("main > section, main > .photo-immersive-panel", { y: 10, autoAlpha: 0, duration: 0.46, stagger: 0.04 }, 0.12);

        ScrollTrigger.batch(".reveal-item, .work-card, .honor-tile, .photo-list-item", {
          start: "top 88%",
          once: true,
          onEnter: (elements) => {
            gsap.fromTo(elements, { y: 24, autoAlpha: 0 }, { y: 0, autoAlpha: 1, duration: 0.62, stagger: 0.06, ease: "power2.out" });
          },
        });
      }
    </script>
  </body>
</html>
