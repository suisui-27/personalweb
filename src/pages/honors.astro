---
import BaseLayout from "../layouts/BaseLayout.astro";
import { honorItems } from "../data/honors";
import { profile } from "../data/profile";
import selfIntroText from "../../自我介绍.txt?raw";

const introLines = selfIntroText.trim().split(/\r?\n/);
const displayName = introLines[0] || profile.name;
const role = introLines[1] || "哈尔滨工业大学机械工程硕士";
const discipline = introLines[2] || profile.tagline;
const introParagraphs = selfIntroText
  .trim()
  .split(/\r?\n\s*\r?\n/)
  .slice(1)
  .map((paragraph) => paragraph.replace(/\s*\r?\n\s*/g, " ").trim())
  .filter(Boolean);

const educationRecords = profile.education.slice(0, 2);
---

<BaseLayout title="个人成长 | 个人作品集">
  <main class="growth-page leadership-page">
    <section class="leadership-hero" aria-labelledby="growth-title">
      <div class="leadership-hero-inner">
        <div class="leadership-title-block reveal-item">
          <h1 id="growth-title">{displayName}</h1>
          <p class="leadership-role">{role}</p>
          <p class="leadership-discipline">{discipline}</p>
        </div>
        <figure class="leadership-portrait reveal-item">
          <img src="/assets/profile/home-portrait-cutout.png" alt={`${displayName}个人主页照片`} />
        </figure>
      </div>
    </section>

    <section class="leadership-bio" aria-label="个人介绍">
      <div class="leadership-bio-grid">
        <aside class="leadership-education reveal-item" aria-label="教育背景">
          <p>教育背景</p>
          {educationRecords.map((item) => (
            <article>
              <span>{item.period}</span>
              <strong>{item.school}</strong>
              <small>{item.major} / {item.degree}</small>
            </article>
          ))}
        </aside>

        <div class="leadership-copy">
          {introParagraphs.map((paragraph) => <p class="reveal-item">{paragraph}</p>)}
        </div>
      </div>
    </section>

    <section class="leadership-honors" aria-labelledby="honors-title">
      <div class="leadership-section-head reveal-item">
        <p>Honors</p>
        <h2 id="honors-title">荣誉奖项</h2>
      </div>

      <div class="leadership-honor-list">
        {honorItems.map((honor) => (
          <a class="leadership-honor-row reveal-item" href={`/honors/${honor.slug}/`}>
            <span class="leadership-honor-year">{honor.year}</span>
            <span class="leadership-honor-copy">
              <small>{honor.category}</small>
              <strong>{honor.title}</strong>
            </span>
            <span class="leadership-honor-action">查看详情</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
