---
import BaseLayout from "../layouts/BaseLayout.astro";
import { honorItems } from "../data/honors";
import { profile } from "../data/profile";
---

<BaseLayout title="个人成长 | 个人作品集">
  <main class="visual-page growth-page">
    <section class="module-note growth-note">
      <p>{profile.tagline}</p>
    </section>

    <section class="section dark-section growth-section">
      <div class="growth-overview">
        <div class="growth-intro reveal-item">
          {profile.bio.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <div class="growth-education reveal-item">
          {profile.education.map((item) => (
            <article>
              <span>{item.period}</span>
              <strong>{item.school}</strong>
              <p>{item.major} / {item.degree}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="honor-board">
        {honorItems.map((honor) => (
          <a class={`honor-row ${honor.kind === "document" ? "is-document" : ""}`} href={honor.src} target="_blank" rel="noreferrer">
            <div class="honor-year">{honor.year}</div>
            <div class="honor-row-copy">
              <span>{honor.category}</span>
              <h2>{honor.title}</h2>
            </div>
            <div class="honor-proof" aria-hidden="true">
              {honor.kind === "document" ? (
                <span>DOCX</span>
              ) : (
                <img src={honor.preview || honor.src} alt="" loading="lazy" />
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
