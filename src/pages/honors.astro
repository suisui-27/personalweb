---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { honorItems } from "../data/honors";
---

<BaseLayout title="个人成长 | 个人作品集">
  <main>
    <section class="section">
      <PageHeader
        eyebrow="Awards & Recognition"
        title="个人成长"
        description="竞赛奖项与奖学金记录，作为设计与工程学习路径的旁证。"
      />
      <div class="honor-list">
        {honorItems.map((honor, index) => (
          <article class="honor-card">
            <div class="honor-index">{String(index + 1).padStart(2, "0")}</div>
            <div class="honor-copy">
              <span>{honor.year}</span>
              <h3>{honor.title}</h3>
              <p>{honor.category}</p>
            </div>
            <img src={honor.src} alt={honor.title} loading="lazy" />
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
