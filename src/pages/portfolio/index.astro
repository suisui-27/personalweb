---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkCard from "../../components/WorkCard.astro";

const portfolio = (await getCollection("portfolio")).sort((a, b) =>
  b.data.year.localeCompare(a.data.year)
);
---

<BaseLayout title="工业产品 | 个人作品集">
  <main class="visual-page portfolio-page">
    <section class="module-note">
      <p>把产品概念、结构推演和建模渲染统一放进同一套尺度里浏览。封面保持完整显示，方便比较不同项目的比例、轮廓和细节。</p>
    </section>

    <section class="section dark-section">
      <div class="card-grid portfolio-grid">
        {portfolio.map((item) => (
          <WorkCard
            href={`/portfolio/${item.slug}/`}
            title={item.data.title}
            category={`${item.data.category} / ${item.data.year}`}
            summary={item.data.summary}
            cover={item.data.cover}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
