---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkCard from "../../components/WorkCard.astro";
import PageHeader from "../../components/PageHeader.astro";

const portfolio = (await getCollection("portfolio")).sort((a, b) =>
  b.data.year.localeCompare(a.data.year)
);
---

<BaseLayout title="工业产品 | 个人作品集">
  <main>
    <section class="section">
      <PageHeader
        eyebrow="Product & System"
        title="工业产品"
        description="工业设计、界面、产品概念和 3D 模型项目。每个项目包含封面、摘要、标签和详情图廊。"
      />
      <div class="card-grid">
        {portfolio.map((item) => (
          <WorkCard
            href={`/portfolio/${item.slug}/`}
            title={item.data.title}
            category={`${item.data.category} / ${item.data.year}`}
            summary={item.data.summary}
            cover={item.data.cover}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
