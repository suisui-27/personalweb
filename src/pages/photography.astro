---
import BaseLayout from "../layouts/BaseLayout.astro";
import { photographyItems } from "../data/photography";
---

<BaseLayout title="摄影作品 | 个人作品集">
  <main>
    <section class="photo-section">
      <div class="photo-copy section-head page-head">
        <p class="eyebrow">Immersive Photography</p>
        <h1>摄影作品</h1>
        <p>旅途、风景和空间记录。照片以拍摄地命名，用横向沉浸式画廊让风景本身成为第一视觉。</p>
      </div>
      <div class="photo-immersive">
        {photographyItems.map((photo) => (
          <article class="photo-card">
            <img src={photo.src} alt={photo.place} loading="lazy" />
            <div class="place-tag">
              <span>{photo.note}</span>
              <strong>{photo.place}</strong>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
