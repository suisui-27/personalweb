---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { honorItems } from "../../data/honors";

export function getStaticPaths() {
  return honorItems.map((honor) => ({
    params: { slug: honor.slug },
    props: { honor },
  }));
}

const { honor } = Astro.props;
const materials = honor.materials ?? [];
---

<BaseLayout title={`${honor.title} | 个人成长`}>
  <main class="honor-detail-page">
    <a class="project-back-link" href="/honors/">返回个人成长</a>

    <section class="honor-detail-hero">
      <div class="honor-detail-copy">
        <p class="leadership-kicker">{honor.category}</p>
        <h1 style={`--title-chars: ${Math.max(honor.title.length, 1)}`}>{honor.title}</h1>
        <p>{honor.year}</p>
      </div>
    </section>

    <section class="honor-detail-proof" aria-label="奖项证明">
      {materials.length === 0 ? (
        <div class="honor-document-panel">
          <span>Pending</span>
          <h2>证明材料待补充</h2>
        </div>
      ) : (
        materials.map((material) =>
          material.kind === "image" ? (
            <figure>
              <img src={material.src} alt={`${honor.title} - ${material.title}`} />
              <figcaption>{material.title}</figcaption>
            </figure>
          ) : (
            <div class="honor-document-panel honor-document-panel--secondary">
              <span>{material.label ?? "FILE"}</span>
              <h2>{material.title}</h2>
              <a class="button" href={material.src} target="_blank" rel="noreferrer">打开材料</a>
            </div>
          )
        )
      )}
    </section>
  </main>
</BaseLayout>
