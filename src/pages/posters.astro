---
import BaseLayout from "../layouts/BaseLayout.astro";
import PosterCarousel from "../components/PosterCarousel";
import { posterItems } from "../data/posters";
---

<BaseLayout title="平面设计 | 个人作品集">
  <main>
    <section class="section alt" aria-labelledby="poster-title">
      <div class="section-head">
        <p class="eyebrow">Campus Visual Communication</p>
        <h1 id="poster-title">平面设计</h1>
        <p>学校新闻网站助管期间参与设计的海报，按节庆、校庆、专题宣传和新闻栏目组织展示。</p>
      </div>
      <PosterCarousel items={posterItems} client:visible />
    </section>
  </main>
</BaseLayout>
