
---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import ThreeAccent from "../components/ThreeAccent";
import PosterCarousel from "../components/PosterCarousel";
import { photographyItems } from "../data/photography";
import { honorItems } from "../data/honors";
import { posterItems } from "../data/posters";

const portfolio = (await getCollection("portfolio"))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 6);
const photos = photographyItems;
const honors = honorItems;
---

<BaseLayout>
  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-media" aria-hidden="true"></div>
      <ThreeAccent client:visible />
      <div class="hero-copy">
        <p class="eyebrow">Industrial Design / Mechanical Engineering</p>
        <h1 id="hero-title">把设计直觉落到<br />可验证的工程细节</h1>
        <p>
          本科工业设计，研究生机械工程。这个网站整理产品设计、校园官网视觉、摄影作品与阶段性荣誉，
          既保留设计表达，也强调结构、逻辑和可持续更新。
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/portfolio/">查看作品</a>
          <a class="button ghost" href="/photography/">查看摄影</a>
        </div>
      </div>
    </section>


    <section class="section" aria-labelledby="portfolio-title">
      <div class="section-head">
        <p class="eyebrow">Product & System</p>
        <h2 id="portfolio-title">工业设计</h2>
        <p>以问题定义、功能推演和形态表达为主线。每个项目都可以独立补充正文、详情图和设计说明。</p>
      </div>
      <div class="card-grid">
        {portfolio.map((item) => (
          <WorkCard
            href={`/portfolio/${item.slug}/`}
            title={item.data.title}
            category={item.data.category}
            summary={item.data.summary}
            cover={item.data.cover}
          />
        ))}
      </div>
    </section>

    <section class="section alt" aria-labelledby="poster-title">
      <div class="section-head">
        <p class="eyebrow">Campus Visual Communication</p>
        <h2 id="poster-title">平面设计</h2>
        <p>学校新闻网站助管期间参与设计的海报，按节庆、校庆、专题宣传和新闻栏目组织展示。</p>
      </div>
      <PosterCarousel items={posterItems} client:visible />
    </section>

    <section class="photo-section" aria-labelledby="photo-title">
      <div class="photo-copy">
        <p class="eyebrow">Immersive Photography</p>
        <h2 id="photo-title">摄影照片</h2>
        <p>照片以拍摄地命名，用横向沉浸式画廊让风景本身成为第一视觉。</p>
      </div>
      <div class="photo-immersive">
        {photos.map((photo) => (
          <article class="photo-card">
            <img src={photo.src} alt={photo.place} loading="lazy" />
            <div class="place-tag">
              <span>拍摄地</span>
              <strong>{photo.place}</strong>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section blue" aria-labelledby="honors-title">
      <div class="section-head">
        <p class="eyebrow">Awards & Recognition</p>
        <h2 id="honors-title">荣誉奖项</h2>
        <p>奖学金、设计竞赛和学习阶段成果，作为设计与工程学习路径的旁证。</p>
      </div>
      <div class="honor-list">
        {honors.map((honor, index) => (
          <article class="honor-card">
            <div class="honor-index">{String(index + 1).padStart(2, "0")}</div>
            <div class="honor-copy">
              <span>{honor.year}</span>
              <h3>{honor.title}</h3>
              <p>{honor.category}</p>
            </div>
            <img src={honor.src} alt={honor.title} loading="lazy" />
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
