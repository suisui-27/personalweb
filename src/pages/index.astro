---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import ThreeAccent from "../components/ThreeAccent";
import { photographyItems } from "../data/photography";
import { honorItems } from "../data/honors";
import { posterItems } from "../data/posters";

const portfolio = (await getCollection("portfolio"))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 6);
const posts = (await getCollection("posts"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
const photos = photographyItems.slice(0, 5);
const honors = honorItems.slice(0, 3);
const posters = posterItems.slice(0, 5);
---

<BaseLayout>
  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-media" aria-hidden="true"></div>
      <ThreeAccent client:visible />
      <div class="hero-copy">
        <p class="eyebrow">Industrial Design / Mechanical Engineering</p>
        <h1 id="hero-title">把设计直觉落到<br />可验证的工程细节</h1>
        <p>
          本科工业设计，研究生机械工程。这个网站整理产品设计、校园官网视觉、摄影作品、阶段性荣誉与博客记录，
          既保留设计表达，也强调结构、逻辑和可持续更新。
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/portfolio/">查看作品</a>
          <a class="button ghost" href="/blog/">阅读博客</a>
        </div>
      </div>
    </section>

    <section class="intro-band" aria-label="个人定位">
      <div>
        <span>专业背景</span>
        <strong>工业设计 -> 机械工程</strong>
      </div>
      <div>
        <span>能力关键词</span>
        <strong>产品思维 / 视觉系统 / 结构意识</strong>
      </div>
      <div>
        <span>作品类型</span>
        <strong>3D 建模、界面、海报、摄影</strong>
      </div>
    </section>

    <section class="section" aria-labelledby="portfolio-title">
      <div class="section-head">
        <p class="eyebrow">Product & System</p>
        <h2 id="portfolio-title">工业设计作品</h2>
        <p>以问题定义、功能推演和形态表达为主线。每个项目都可以独立补充正文、详情图和设计说明。</p>
      </div>
      <div class="card-grid">
        {portfolio.map((item) => (
          <WorkCard
            href={`/portfolio/${item.slug}/`}
            title={item.data.title}
            category={item.data.category}
            summary={item.data.summary}
            cover={item.data.cover}
          />
        ))}
      </div>
    </section>

    <section class="section alt" aria-labelledby="poster-title">
      <div class="section-head">
        <p class="eyebrow">Campus Visual Communication</p>
        <h2 id="poster-title">平面设计</h2>
        <p>学校新闻网站助管期间参与设计的海报，按节庆、校庆、专题宣传和新闻栏目组织展示。</p>
      </div>
      <div class="poster-grid">
        {posters.map((poster) => (
          <figure class="poster-card">
            <img src={poster.src} alt={poster.title} loading="lazy" />
            <figcaption>
              <span>{poster.category}</span>
              <strong>{poster.title}</strong>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="photo-section" aria-labelledby="photo-title">
      <div class="photo-copy">
        <p class="eyebrow">Immersive Photography</p>
        <h2 id="photo-title">摄影照片</h2>
        <p>照片以拍摄地命名，用横向沉浸式画廊让风景本身成为第一视觉。</p>
      </div>
      <div class="photo-immersive">
        {photos.map((photo) => (
          <article class="photo-card">
            <img src={photo.src} alt={photo.place} loading="lazy" />
            <div class="place-tag">
              <span>拍摄地</span>
              <strong>{photo.place}</strong>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section blue" aria-labelledby="honors-title">
      <div class="section-head">
        <p class="eyebrow">Awards & Recognition</p>
        <h2 id="honors-title">荣誉奖项</h2>
        <p>奖学金、设计竞赛和学习阶段成果，作为设计与工程学习路径的旁证。</p>
      </div>
      <div class="honor-list">
        {honors.map((honor, index) => (
          <article class="honor-card">
            <div class="honor-index">{String(index + 1).padStart(2, "0")}</div>
            <div class="honor-copy">
              <span>{honor.year}</span>
              <h3>{honor.title}</h3>
              <p>{honor.category}</p>
            </div>
            <img src={honor.src} alt={honor.title} loading="lazy" />
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="blog-title">
      <div class="section-head">
        <p class="eyebrow">Notes</p>
        <h2 id="blog-title">博客记录</h2>
        <p>记录项目复盘、工具链、视觉系统和设计工程之间的阶段性思考。</p>
      </div>
      <div class="card-grid">
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${post.slug}/`}>
            {post.data.cover && <img src={post.data.cover} alt={post.data.title} loading="lazy" />}
            <div class="card-copy">
              <span class="card-kicker">{post.data.date.toLocaleDateString("zh-CN")}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.summary}</p>
              <strong class="card-link">阅读文章</strong>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
