---
interface Props {
  href: string;
  title: string;
  category: string;
  summary: string;
  cover: string;
}

const { href, title, category, summary, cover } = Astro.props;
---

<a class="work-card" href={href}>
  <div class="work-card-media">
    <img src={cover} alt={title} loading="lazy" />
  </div>
  <div class="card-copy">
    <span class="card-kicker">{category}</span>
    <h3>{title}</h3>
    <p>{summary}</p>
  </div>
</a>
