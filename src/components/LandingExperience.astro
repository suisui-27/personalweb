---
interface Props {
  videoSrc?: string;
  randomize?: boolean;
}

const { videoSrc, randomize = false } = Astro.props;
const imageSrc = "/assets/hero/home-hero.jpg";
const videoVariants = {
  studio: {
    src: "/assets/hero/home-background-pingpong-pexels-7828922.mp4",
    poster: "/assets/hero/home-background-poster-pexels-7828922.jpg",
  },
  architecture: {
    src: "/assets/hero/home-background-pingpong-architecture-pexels-7311573.mp4",
    poster: "/assets/hero/home-background-poster-architecture-pexels-7311573.jpg",
  },
};
const entries = [
  { href: "/portfolio/", label: "工业产品", uploadType: "portfolio" },
  { href: "/posters/", label: "平面设计", uploadType: "poster" },
  { href: "/photography/", label: "摄影作品", uploadType: "photography" },
  { href: "/honors/", label: "个人成长", uploadType: "honor" },
];
---

<main class="landing" data-random-landing={randomize ? "true" : undefined}>
  <div
    class:list={["landing-media", { "has-video": Boolean(videoSrc) }]}
    data-landing-media={randomize ? "true" : undefined}
    data-image-src={randomize ? imageSrc : undefined}
    data-studio-src={randomize ? videoVariants.studio.src : undefined}
    data-studio-poster={randomize ? videoVariants.studio.poster : undefined}
    data-architecture-src={randomize ? videoVariants.architecture.src : undefined}
    data-architecture-poster={randomize ? videoVariants.architecture.poster : undefined}
    aria-hidden="true"
  >
    {videoSrc && (
      <video class="landing-video" src={videoSrc} autoplay muted loop playsinline preload="auto"></video>
    )}
    {!videoSrc && !randomize && (
      <img class="landing-image" src={imageSrc} alt="" fetchpriority="high" />
    )}
  </div>
  <div class="landing-overlay" aria-hidden="true"></div>

  <div class="landing-content">
    <div class="landing-head">
      <p class="landing-eyebrow">Industrial Design / Mechanical Engineering</p>
      <h1 class="landing-title">
        <span class="title-line title-line-left">把设计直觉落到</span>
        <span class="title-line title-line-right">可验证的工程细节</span>
      </h1>
    </div>

    <nav class="landing-entries" aria-label="作品入口">
      {entries.map((item) => (
        <a class="landing-entry" href={item.href} data-local-upload={import.meta.env.DEV ? item.uploadType : undefined}>
          <span class="entry-title"><span class="entry-dot" aria-hidden="true"></span>{item.label}</span>
          <span class="entry-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="12" x2="20" y2="12"></line>
              <polyline points="14,6 20,12 14,18"></polyline>
            </svg>
          </span>
        </a>
      ))}
    </nav>
  </div>
</main>

{randomize && (
  <script is:inline>
    (() => {
      const media = document.querySelector("[data-landing-media]");
      if (!(media instanceof HTMLElement)) return;

      const variants = ["image", "studio", "architecture"];
      const bagKey = "suisui-home-variant-bag-v1";
      const lastKey = "suisui-home-last-variant-v1";
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
      const hasConstrainedNetwork = Boolean(
        connection?.saveData || ["slow-2g", "2g"].includes(connection?.effectiveType)
      );

      const shuffle = (items) => {
        const result = [...items];
        for (let index = result.length - 1; index > 0; index -= 1) {
          const swapIndex = Math.floor(Math.random() * (index + 1));
          [result[index], result[swapIndex]] = [result[swapIndex], result[index]];
        }
        return result;
      };

      let selected = variants[Math.floor(Math.random() * variants.length)];
      try {
        const lastVariant = localStorage.getItem(lastKey);
        let bag = JSON.parse(localStorage.getItem(bagKey) || "[]");
        if (!Array.isArray(bag) || bag.some((item) => !variants.includes(item)) || bag.length === 0) {
          bag = shuffle(variants);
          if (bag[0] === lastVariant && bag.length > 1) {
            [bag[0], bag[1]] = [bag[1], bag[0]];
          }
        }
        selected = bag.shift() || selected;
        localStorage.setItem(bagKey, JSON.stringify(bag));
        localStorage.setItem(lastKey, selected);
      } catch {}

      media.dataset.variant = selected;

      const reveal = (element) => element.classList.add("is-ready");
      const mountImage = () => {
        media.classList.remove("has-video");
        media.dataset.variant = "image";
        const image = document.createElement("img");
        image.className = "landing-image";
        image.alt = "";
        image.fetchPriority = "high";
        image.addEventListener("load", () => reveal(image), { once: true });
        image.src = media.dataset.imageSrc;
        media.replaceChildren(image);
        if (image.complete) reveal(image);
      };

      if (selected === "image") {
        mountImage();
        return;
      }

      const video = document.createElement("video");
      const sourceKey = selected === "architecture" ? "architectureSrc" : "studioSrc";
      const posterKey = selected === "architecture" ? "architecturePoster" : "studioPoster";

      if (prefersReducedMotion || hasConstrainedNetwork) {
        const poster = document.createElement("img");
        poster.className = "landing-image landing-video-poster";
        poster.alt = "";
        poster.fetchPriority = "high";
        poster.addEventListener("load", () => reveal(poster), { once: true });
        poster.src = media.dataset[posterKey];
        media.classList.add("has-video");
        media.replaceChildren(poster);
        if (poster.complete) reveal(poster);
        return;
      }

      video.className = "landing-video is-ready";
      video.autoplay = true;
      video.muted = true;
      video.loop = true;
      video.playsInline = true;
      video.preload = "auto";
      video.poster = media.dataset[posterKey];
      video.addEventListener("error", mountImage, { once: true });
      video.src = media.dataset[sourceKey];
      media.classList.add("has-video");
      media.replaceChildren(video);
      video.play().catch(() => {});
    })();
  </script>
)}

<style>
  .landing {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 100vh;
    min-height: 100dvh;
    color: var(--white);
    overflow: hidden;
    isolation: isolate;
  }

  .landing-media {
    position: absolute;
    inset: 0;
    z-index: -2;
    background: #0c1012;
  }

  .landing-image,
  .landing-video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  [data-random-landing] .landing-image,
  [data-random-landing] .landing-video {
    opacity: 0;
    transition: opacity 420ms ease;
  }

  [data-random-landing] .landing-image.is-ready,
  [data-random-landing] .landing-video.is-ready {
    opacity: 1;
  }

  .landing-video {
    height: 110%;
    object-position: center center;
    transform: translateY(-9%);
  }

  .landing-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(189, 140, 58, 0.12) 0%, transparent 45%),
      linear-gradient(180deg, rgba(12, 16, 18, 0.42) 0%, rgba(12, 16, 18, 0.74) 58%, rgba(12, 16, 18, 0.92) 100%);
  }

  .landing-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 110px 20px 48px;
  }

  .landing-head {
    width: 100%;
    margin-bottom: 40px;
  }

  .landing-eyebrow {
    position: relative;
    display: inline-block;
    margin: 0 0 12px;
    padding-left: 16px;
    color: var(--gold);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .landing-eyebrow::before {
    position: absolute;
    left: 0;
    top: 50%;
    width: 5px;
    height: 5px;
    content: "";
    background: var(--gold);
    border-radius: 50%;
    transform: translateY(-50%);
  }

  .landing-title {
    display: flex;
    flex-direction: column;
    gap: 0.22em;
    margin: 0;
    font-weight: 500;
    font-style: italic;
    line-height: 1.22;
    letter-spacing: 0.02em;
    opacity: 0.7;
    transition: opacity 300ms ease, color 300ms ease;
  }

  .landing-title:hover {
    color: rgba(255, 253, 250, 1);
    text-shadow: none;
    opacity: 1;
  }

  .title-line {
    display: block;
    white-space: nowrap;
  }

  .title-line-left {
    text-align: left;
  }

  .title-line-right {
    text-align: right;
  }

  .landing-entries {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    width: 100%;
  }

  .landing-entry {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 8px 0 22px;
    color: rgba(255, 253, 250, 0.55);
    border-top: 1px solid rgba(255, 253, 250, 0.85);
    transition: color 260ms ease, border-color 260ms ease;
  }

  .landing-entry:hover,
  .landing-entry:focus-visible,
  .landing-entry:hover:not(:first-child),
  .landing-entry:focus-visible:not(:first-child) {
    color: rgba(255, 253, 250, 0.95);
    border-top-color: var(--gold);
    outline: 0;
  }

  .landing-entry:not(:first-child) {
    border-top-color: rgba(255, 253, 250, 0.18);
  }

  .entry-title {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.25;
    white-space: nowrap;
  }

  .entry-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: currentColor;
    border-radius: 50%;
    vertical-align: middle;
    transition: color 260ms ease;
  }

  .entry-arrow {
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    flex-shrink: 0;
    transition: color 260ms ease;
  }

  .entry-arrow svg {
    width: 20px;
    height: 20px;
    transform: rotate(-45deg);
    transition: transform 260ms cubic-bezier(0.34, 1.56, 0.64, 1), color 260ms ease;
  }

  .landing-entry:hover .entry-arrow svg,
  .landing-entry:focus-visible .entry-arrow svg {
    transform: rotate(0deg);
  }

  @media (min-width: 561px) {
    .landing-content {
      padding: 120px 48px 80px;
    }

    .landing-head {
      margin-bottom: 56px;
    }

    .landing-title {
      font-size: 52px;
      line-height: 1.18;
    }

    .landing-entries {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .landing-entry {
      padding: 10px 0 24px;
    }

    .landing-entry:not(:first-child) {
      border-top-color: rgba(255, 253, 250, 0.85);
    }

    .entry-title {
      font-size: 22px;
    }
  }

  @media (min-width: 981px) {
    .landing-content {
      padding: 120px 56px 100px;
    }

    .landing-head {
      margin-bottom: 64px;
    }

    .landing-title {
      font-size: 60px;
    }

    .landing-entries {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }

    .entry-title {
      font-size: 22px;
    }
  }

  @media (min-width: 1200px) {
    .landing {
      display: block;
      width: 100vw;
      height: 100vh;
      min-height: 100vh;
    }

    .landing-content {
      position: absolute;
      left: 50%;
      bottom: 10%;
      width: 55vw;
      max-width: none;
      margin: 0;
      padding: 0;
      transform: translateX(-50%);
    }

    .landing-head {
      margin-bottom: 4vmin;
    }

    .landing-eyebrow {
      margin-bottom: 1.5vmin;
      padding-left: 1.4vmin;
      font-size: 1.1vmin;
    }

    .landing-eyebrow::before {
      width: 0.45vmin;
      height: 0.45vmin;
    }

    .landing-title {
      font-size: 5vmin;
      line-height: 1.22;
    }

    .landing-entries {
      gap: 2.2vmin;
    }

    .landing-entry {
      padding-top: 0.75vmin;
      padding-bottom: 1.25vmin;
    }

    .entry-title {
      font-size: 1.8vmin;
    }

    .entry-arrow {
      width: 3vmin;
      height: 3vmin;
    }

    .entry-arrow svg {
      width: 1.6vmin;
      height: 1.6vmin;
    }
  }
</style>
